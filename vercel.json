{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/about", "destination": "/about-us", "permanent": true },
    { "source": "/contact", "destination": "/contact-us", "permanent": true },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "thehouseofscale.com" }],
      "destination": "https://www.thehouseofscale.com/:path*",
      "permanent": true
    }
  ]
}
